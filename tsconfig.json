{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2015",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["acode-plugin-types"]
  },
  "include": ["src/**/*"],
  "exclude": ["./dist/**/*", "src/**/*.test.ts"]
}
